# ===========================================================================
# Code repo only. Data, models, venv, and outputs are regenerated locally —
# see README.md "Setup". Placeholder dirs are kept via .gitkeep.
# ===========================================================================

# --- Python / env ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.cache/

# --- Virtual env / nvcc shim inside the model repo ---
OpenDriveVLA/.cache/

# --- Large data (regenerate via the pipeline; see README) ---
data_carla/raw/*
!data_carla/raw/.gitkeep
data_carla/processed/*
!data_carla/processed/.gitkeep
data_carla/plan_cache/
data_carla/v1.0-mini/

data/nuscenes/maps/
data/nuscenes/basemap/
data/nuscenes/expansion/
data/nuscenes/prediction/
data/nuscenes/v1.0-carla/
data/nuscenes/*.pkl
data/nuscenes/LICENSE

# nuScenes mini used for the UniAD domain-gap sanity test (data, kept locally)
nuscenes_sample_test/

# Regenerable GT/validation overlays (produced by the validation scripts)
data/gt_overlays_validate/
data/gt_overlays/
data/gt_train_viz/

# Reference paper PDF (large binary, not code)
opendrivevlapaper.pdf

# --- Models: base, merged models, full weights and resumable training state are
#     big / re-obtainable. Track ONLY the small LoRA adapter files
#     (adapter_config.json + adapter_model.*) for any run — e.g.
#     OpenDriveVLA-0.5B-carla/, OpenDriveVLA-0.5B-carla-dagger1/, ... ---
checkpoints/OpenDriveVLA-0.5B/
checkpoints/_smoke/
checkpoints/**/merged*/
checkpoints/**/last_state/
checkpoints/**/train_state.pt
# Full (non-adapter) model weights anywhere under checkpoints (adapter_model.* kept).
checkpoints/**/model*.safetensors
checkpoints/**/pytorch_model*.bin
# Tokenizer/vocab re-saved in every checkpoint dir — re-obtainable from the base;
# don't track (keeps repo to just adapter_config.json + adapter_model.* + README).
checkpoints/**/tokenizer.json
checkpoints/**/tokenizer_config.json
checkpoints/**/vocab.json
checkpoints/**/merges.txt
checkpoints/**/special_tokens_map.json
checkpoints/**/added_tokens.json
checkpoints/**/generation_config.json
# Track only the LATEST adapter per run; ignore intermediate-epoch checkpoints
# (kept: OpenDriveVLA-0.5B-carla/epoch_003, OpenDriveVLA-0.5B-carla-dagger1/epoch_002).
checkpoints/OpenDriveVLA-0.5B-carla/epoch_001/
checkpoints/OpenDriveVLA-0.5B-carla/epoch_002/
checkpoints/OpenDriveVLA-0.5B-carla-dagger1/epoch_001/

# --- Runtime outputs ---
outputs/*
!outputs/.gitkeep
OpenDriveVLA/output/

# --- Upstream OpenDriveVLA eval assets (big, re-downloadable, unused by CARLA pipeline) ---
OpenDriveVLA/drivevla/eval_share/gt/

# --- Misc ---
*.log
.DS_Store

# --- Generic coding-guideline docs (not useful to others) ---
CLAUDE.md
EXAMPLES.md

# UniAD stage-1 checkpoints (a `git stash -u` once swept these into a stash)
checkpoints/**/*.pth
checkpoints/**/latest.pth
